"""
Aguarda alguns segundos (para você posicionar o mouse), imprime as
coordenadas atuais do cursor e aplica uma rolagem de teste.

Útil para anotar x/y ao montar automações com PyAutoGUI.
"""

import time
from pyautogui import position, scroll

PAUSA_SEGUNDOS = 3
ROLAGEM_UNIDADES = 200  # positivo = rola o conteúdo para cima


def main() -> None:
    time.sleep(PAUSA_SEGUNDOS)
    x, y = position()
    print(f"Posição do mouse — x: {x},  y: {y}")
    scroll(ROLAGEM_UNIDADES)


if __name__ == "__main__":
    main()
